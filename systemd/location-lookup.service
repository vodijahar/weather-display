[Unit]
Description=Weather Display Location Lookup On Boot
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/weather-display/app
EnvironmentFile=-/etc/default/weather-display
ExecStart=/usr/bin/python3 /opt/weather-display/app/boot_location.py
NoNewPrivileges=yes
PrivateTmp=yes
UMask=0077

[Install]
WantedBy=multi-user.target
