WAVESHARE_DRIVER=V4
DISPLAY_ROTATE=0
DEVICE_HOSTNAME=weather-display
SSH_USER=weather
SSH_PASSWORD=weather

# Change DEVICE_HOSTNAME if you have more than one Pi on the same network.
# Change SSH_PASSWORD after the first login.

# Optional Wi-Fi setup for custom-image flashing flows where Raspberry Pi
# Imager does not offer OS customisation. This file lives on the boot
# partition before first boot, so treat it as sensitive.
# WIFI_SSID=YourNetworkName
# WIFI_PASSWORD=YourNetworkPassword
# WIFI_COUNTRY=ZA
# WIFI_HIDDEN=0

# Supported values:
# WAVESHARE_DRIVER=V2
# WAVESHARE_DRIVER=V3
# WAVESHARE_DRIVER=V4

# Use these if your display is rotated:
# DISPLAY_ROTATE=90
# DISPLAY_ROTATE=180
# DISPLAY_ROTATE=270

# Optional manual location override:
# WEATHER_LAT=-25.731340
# WEATHER_LON=28.218370
# WEATHER_CITY=Pretoria
